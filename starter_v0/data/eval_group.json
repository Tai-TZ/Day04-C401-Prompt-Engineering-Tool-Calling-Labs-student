    {
      "id": "G10_policy_citation",
      "phase": "B",
      "suite": "group",
      "query": "Tìm trong policy nội bộ về trích dẫn nguồn khi publish bài viết",
      "failure_type": "wrong_tool",
      "expect": {
        "tool_calls": [
          {
